            until troot.Velocity.Magnitude > 1000 or thum.Health <= 0 or not tchar:IsDescendantOf(workspace) or targetPlayer.Parent ~= Players
            workspace.CurrentCamera.CameraSubject = humanoid
        end
    end
end

