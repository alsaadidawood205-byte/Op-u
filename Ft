local function sendchat(msg)
    if not msg or msg == "" then return end
    local tcs = game:GetService("TextChatService")
    if tcs.ChatVersion == Enum.ChatVersion.LegacyChatService then
        local success, err = pcall(function()
            game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents").SayMessageRequest:FireServer(msg, "All")
        end)
        if not success then warn("خطأ في إرسال الدردشة: " .. err) end
    else
        local chat = tcs.ChatInputBarConfiguration and tcs.ChatInputBarConfiguration.TargetTextChannel
        if chat then
            local success, err = pcall(function() chat:SendAsync(msg) end)
            if not success then warn("خطأ في إرسال الدردشة: " .. err) end
        end
    end
end

